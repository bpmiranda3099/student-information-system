generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  student
  faculty
  admin
  enrollee
}

enum AdmissionType {
  freshman
  transferee
}

enum AdmissionStatus {
  draft
  submitted
  under_review
  denied
  accepted
  closed
}

enum SubjectRequirementType {
  required
  elective
}

enum SupportTicketStatus {
  open
  in_progress
  resolved
  closed
}

enum ConductReportStatus {
  open
  under_review
  resolved
  dismissed
}

enum EnrollmentStatus {
  pending
  approved
  dropped
}

enum TermStatus {
  upcoming
  active
  archived
}

enum GradeComponentType {
  quiz
  seatwork
  activity
  project
  exam
  extracurricular
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

enum AiRequestStatus {
  pending
  completed
  failed
}

enum CalendarEventType {
  holiday
  exam
  enrollment
  break
  event
  no_classes
}

enum CalendarEventSource {
  manual
  official_ph
}

enum AnnouncementCategory {
  news
  no_classes
  disaster
  holiday
}

enum AnnouncementSeverity {
  low
  medium
  high
  critical
}

enum AnnouncementSource {
  manual
  external
}

enum ExternalAlertProvider {
  pagasa
  usgs
  phivolcs
  ndrrmc
  ph_holidays
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         Role
  photoPath    String?  @map("photo_path")
  bio          String?
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student  Student?
  faculty  Faculty?
  admin    Admin?
  enrollee Enrollee?

  auditLogs            AuditLog[]
  announcementsCreated Announcement[] @relation("AnnouncementCreator")
  onboardingSteps      OnboardingStep[]
  supportTicketsCreated SupportTicket[] @relation("TicketCreator")
  supportTicketsAssigned SupportTicket[] @relation("TicketAssignee")
  conductReportsFiled  ConductReport[] @relation("ConductReporter")
  admissionReviews     AdmissionApplication[] @relation("AdmissionReviewer")

  @@map("users")
}

model Student {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  studentNumber String   @unique @map("student_number")
  programId     String   @map("program_id")
  yearLevel     Int      @default(1) @map("year_level")
  createdAt     DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id])

  enrollments      Enrollment[]
  gradeEntries     GradeEntry[]
  attendanceRecords AttendanceRecord[]
  aiLessonRequests AiLessonRequest[]
  scheduleDrafts   ScheduleDraft[]
  conductReports   ConductReport[]

  @@map("students")
}

model Faculty {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  employeeId String   @unique @map("employee_id")
  department String?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseSections CourseSection[]

  @@map("faculty")
}

model Admin {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Program {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  students    Student[]
  enrollees   Enrollee[]
  curriculum  ProgramCurriculum[]

  @@map("programs")
}

model Subject {
  id          String   @id @default(uuid())
  code        String   @unique
  title       String
  units       Int
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  courseSections CourseSection[]
  curriculum     ProgramCurriculum[]

  @@map("subjects")
}

model AcademicTerm {
  id        String     @id @default(uuid())
  name      String
  year      Int
  semester  Int
  status    TermStatus @default(upcoming)
  startDate DateTime   @map("start_date")
  endDate   DateTime   @map("end_date")
  createdAt DateTime   @default(now()) @map("created_at")

  courseSections CourseSection[]
  calendarEvents AcademicCalendarEvent[]

  @@map("academic_terms")
}

model CourseSection {
  id          String   @id @default(uuid())
  subjectId   String   @map("subject_id")
  termId      String   @map("term_id")
  facultyId   String   @map("faculty_id")
  sectionCode String   @map("section_code")
  capacity    Int
  schedule    String?
  room        String?
  createdAt   DateTime @default(now()) @map("created_at")

  subject Subject      @relation(fields: [subjectId], references: [id])
  term    AcademicTerm @relation(fields: [termId], references: [id])
  faculty Faculty      @relation(fields: [facultyId], references: [id])

  enrollments        Enrollment[]
  gradeScheme        GradeScheme?
  attendanceSessions AttendanceSession[]
  syllabus           Syllabus?
  meetings           SectionMeeting[]
  announcements      Announcement[]

  @@unique([subjectId, termId, sectionCode])
  @@map("course_sections")
}

model Enrollment {
  id         String           @id @default(uuid())
  studentId  String           @map("student_id")
  sectionId  String           @map("section_id")
  status     EnrollmentStatus @default(pending)
  enrolledAt DateTime         @default(now()) @map("enrolled_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  student Student       @relation(fields: [studentId], references: [id])
  section CourseSection @relation(fields: [sectionId], references: [id])

  @@unique([studentId, sectionId])
  @@map("enrollments")
}

model GradeScheme {
  id                 String   @id @default(uuid())
  sectionId          String   @unique @map("section_id")
  isLocked           Boolean  @default(false) @map("is_locked")
  extracurricularMax Float    @default(5) @map("extracurricular_max")
  categoryWeights    Json     @map("category_weights")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  section    CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  components GradeComponent[]

  @@map("grade_schemes")
}

model GradeComponent {
  id        String             @id @default(uuid())
  schemeId  String             @map("scheme_id")
  type      GradeComponentType
  name      String
  maxScore  Float              @map("max_score")
  sequence  Int                @default(0)
  topicTags Json               @default("[]") @map("topic_tags")
  createdAt DateTime           @default(now()) @map("created_at")

  scheme  GradeScheme  @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  entries GradeEntry[]

  @@map("grade_components")
}

model GradeEntry {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  componentId String   @map("component_id")
  score       Float
  recordedAt  DateTime @default(now()) @map("recorded_at")

  student   Student        @relation(fields: [studentId], references: [id])
  component GradeComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([studentId, componentId])
  @@map("grade_entries")
}

model AttendanceSession {
  id        String   @id @default(uuid())
  sectionId String   @map("section_id")
  date      DateTime @db.Date
  topic     String?
  createdAt DateTime @default(now()) @map("created_at")

  section CourseSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  records AttendanceRecord[]

  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        String           @id @default(uuid())
  sessionId String           @map("session_id")
  studentId String           @map("student_id")
  status    AttendanceStatus
  notes     String?
  createdAt DateTime         @default(now()) @map("created_at")

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student           @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@map("attendance_records")
}

model Syllabus {
  id          String   @id @default(uuid())
  sectionId   String   @unique @map("section_id")
  title       String
  description String?
  filePath    String?  @map("file_path")
  createdAt   DateTime @default(now()) @map("created_at")

  section CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("syllabi")
}

model Lesson {
  id         String   @id @default(uuid())
  syllabusId String   @map("syllabus_id")
  title      String
  week       Int
  topics     Json     @default("[]")
  createdAt  DateTime @default(now()) @map("created_at")

  syllabus         Syllabus          @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  files            LessonFile[]
  aiLessonRequests AiLessonRequest[]

  @@map("lessons")
}

model LessonFile {
  id        String   @id @default(uuid())
  lessonId  String   @map("lesson_id")
  fileName  String   @map("file_name")
  filePath  String   @map("file_path")
  mimeType  String   @map("mime_type")
  fileSize  Int      @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_files")
}

model AiLessonRequest {
  id         String          @id @default(uuid())
  studentId  String          @map("student_id")
  lessonId   String          @map("lesson_id")
  weakTopics Json            @map("weak_topics")
  prompt     String
  response   String?
  status     AiRequestStatus @default(pending)
  createdAt  DateTime        @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id])
  lesson  Lesson  @relation(fields: [lessonId], references: [id])

  @@map("ai_lesson_requests")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model MaintenanceJob {
  id          String   @id @default(uuid())
  type        String
  status      String   @default("pending")
  payload     Json?
  result      Json?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("maintenance_jobs")
}

model AcademicCalendarEvent {
  id          String              @id @default(uuid())
  termId      String?             @map("term_id")
  title       String
  description String?
  startDate   DateTime            @map("start_date") @db.Date
  endDate     DateTime            @map("end_date") @db.Date
  type        CalendarEventType
  source      CalendarEventSource @default(manual)
  externalId  String?             @map("external_id")
  allDay      Boolean             @default(true) @map("all_day")
  createdAt   DateTime            @default(now()) @map("created_at")

  term AcademicTerm? @relation(fields: [termId], references: [id])

  @@unique([source, externalId])
  @@map("academic_calendar_events")
}

model SectionMeeting {
  id        String @id @default(uuid())
  sectionId String @map("section_id")
  dayOfWeek Int    @map("day_of_week")
  startTime String @map("start_time")
  endTime   String @map("end_time")
  room      String?

  section CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("section_meetings")
}

model ExternalAlert {
  id          String                @id @default(uuid())
  provider    ExternalAlertProvider
  externalId  String                @map("external_id")
  title       String
  summary     String
  category    AnnouncementCategory
  severity    AnnouncementSeverity  @default(medium)
  issuedAt    DateTime              @map("issued_at")
  rawPayload  Json                  @map("raw_payload")
  dedupeHash  String                @map("dedupe_hash")
  dismissed   Boolean               @default(false)
  createdAt   DateTime              @default(now()) @map("created_at")

  announcements Announcement[]

  @@unique([provider, externalId])
  @@map("external_alerts")
}

model Enrollee {
  id            String        @id @default(uuid())
  userId        String        @unique @map("user_id")
  programId     String?       @map("program_id")
  yearLevel     Int           @default(1) @map("year_level")
  admissionType AdmissionType @default(freshman) @map("admission_type")
  address       String?
  birthDate     DateTime?     @map("birth_date") @db.Date
  guardianName  String?       @map("guardian_name")
  guardianPhone String?       @map("guardian_phone")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  program     Program?              @relation(fields: [programId], references: [id])
  application AdmissionApplication?

  @@map("enrollees")
}

model AdmissionApplication {
  id              String          @id @default(uuid())
  enrolleeId      String          @unique @map("enrollee_id")
  status          AdmissionStatus @default(draft)
  termsVersion    String?         @map("terms_version")
  termsAcceptedAt DateTime?       @map("terms_accepted_at")
  resubmitCount   Int             @default(0) @map("resubmit_count")
  denialReason    String?         @map("denial_reason")
  reviewedById    String?         @map("reviewed_by_id")
  reviewedAt      DateTime?       @map("reviewed_at")
  submittedAt     DateTime?       @map("submitted_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  enrollee   Enrollee @relation(fields: [enrolleeId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("AdmissionReviewer", fields: [reviewedById], references: [id])

  @@map("admission_applications")
}

model ProgramCurriculum {
  id              String                 @id @default(uuid())
  programId       String                 @map("program_id")
  subjectId       String                 @map("subject_id")
  yearLevel       Int                    @map("year_level")
  requirementType SubjectRequirementType @map("requirement_type")
  createdAt       DateTime               @default(now()) @map("created_at")

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([programId, subjectId, yearLevel])
  @@map("program_curriculum")
}

model OnboardingStep {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  stepKey     String   @map("step_key")
  completedAt DateTime @default(now()) @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stepKey])
  @@map("onboarding_steps")
}

model ScheduleDraft {
  id         String   @id @default(uuid())
  studentId  String   @map("student_id")
  termId     String   @map("term_id")
  sectionIds Json     @default("[]") @map("section_ids")
  updatedAt  DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, termId])
  @@map("schedule_drafts")
}

model SupportTicket {
  id           String               @id @default(uuid())
  createdById  String               @map("created_by_id")
  assignedToId String?              @map("assigned_to_id")
  subject      String
  body         String
  category     String
  status       SupportTicketStatus  @default(open)
  resolution   String?
  reopenedOnce Boolean              @default(false) @map("reopened_once")
  resolvedAt   DateTime?            @map("resolved_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  createdBy  User  @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo User? @relation("TicketAssignee", fields: [assignedToId], references: [id])

  @@map("support_tickets")
}

model ConductReport {
  id              String              @id @default(uuid())
  studentId       String              @map("student_id")
  reporterId      String              @map("reporter_id")
  violationType   String              @map("violation_type")
  description     String
  status          ConductReportStatus @default(open)
  resolutionNotes String?             @map("resolution_notes")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  student  Student @relation(fields: [studentId], references: [id])
  reporter User    @relation("ConductReporter", fields: [reporterId], references: [id])

  @@map("conduct_reports")
}

model Announcement {
  id              String               @id @default(uuid())
  title           String
  body            String
  category        AnnouncementCategory
  severity        AnnouncementSeverity @default(medium)
  publishedAt     DateTime             @map("published_at")
  expiresAt       DateTime?            @map("expires_at")
  source          AnnouncementSource   @default(manual)
  externalAlertId String?              @unique @map("external_alert_id")
  sectionId       String?              @map("section_id")
  createdById     String?              @map("created_by_id")
  createdAt       DateTime             @default(now()) @map("created_at")

  externalAlert ExternalAlert? @relation(fields: [externalAlertId], references: [id])
  section       CourseSection? @relation(fields: [sectionId], references: [id])
  createdBy     User?          @relation("AnnouncementCreator", fields: [createdById], references: [id])

  @@map("announcements")
}

model AlertFetchLog {
  id           String                @id @default(uuid())
  provider     ExternalAlertProvider
  status       String
  fetchedCount Int                   @default(0) @map("fetched_count")
  error        String?
  ranAt        DateTime              @default(now()) @map("ran_at")

  @@map("alert_fetch_logs")
}
