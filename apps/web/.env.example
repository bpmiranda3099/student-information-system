# Shown on digital ID card header (Profile page)
NEXT_PUBLIC_INSTITUTION_NAME=Your College Name

# Local dev: proxy through Next.js so auth cookies stay same-origin
NEXT_PUBLIC_API_URL=/api-proxy
API_PROXY_TARGET=http://localhost:4000

# Production (Vercel): see vercel.json — NEXT_PUBLIC_API_URL=/api-proxy, API_PROXY_TARGET=Render URL

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Vercel Supabase integration sets NEXT_PUBLIC_SUPABASE_ANON_KEY; local dev may use either name
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-or-publishable-key
