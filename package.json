{
  "name": "student-information-system",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @sis/api db:generate",
    "db:migrate": "pnpm --filter @sis/api db:migrate",
    "db:seed": "pnpm --filter @sis/api db:seed",
    "db:push": "pnpm --filter @sis/api db:push"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
